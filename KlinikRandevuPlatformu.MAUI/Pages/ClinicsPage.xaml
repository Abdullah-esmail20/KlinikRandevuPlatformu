<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KlinikRandevuPlatformu.MAUI.Pages.ClinicsPage"
             Title="Clinics">

    <CollectionView x:Name="ClinicsView" SelectionMode="Single" SelectionChanged="OnSelected">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Margin="10" Padding="10" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout>
                        <Label Text="{Binding clinicName}" FontAttributes="Bold" />
                        <Label Text="{Binding city}" />
                        <Label Text="{Binding appointmentCount, StringFormat='Appointments: {0}'}" />
                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>